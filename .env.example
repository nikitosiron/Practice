# Логин администратора для входа в /admin
ADMIN_LOGIN=admin

# bcrypt-хеш пароля администратора.
# Как сгенерировать:
#   node -e "console.log(require('bcrypt').hashSync('ВАШ_ПАРОЛЬ', 10))"
ADMIN_PASSWORD_HASH=

# Секрет для подписи cookie сессии. Любая длинная случайная строка.
# Пример генерации:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Опционально: порт HTTP-сервера (по умолчанию 3000)
# PORT=3000
